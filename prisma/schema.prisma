generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Plan {
  free
  premium
}

enum Role {
  USER
  ADMIN
}

enum Gender {
  male
  female
  other
}

enum Goal {
  volume
  definition
  maintenance
  weight_loss
}

enum Level {
  beginner
  intermediate
  advanced
}

enum WorkoutType {
  gym
  home
  bodyweight
}

enum Schedule {
  morning
  midday
  afternoon
  night
}

enum MessageRole {
  user
  assistant
  system
}

enum BadgeId {
  first_step
  week_1
  consistency
  beast
  committed
  weigher
  nutritionist
  social
  sharer
  premium
  challenge_done
  group_top
  iron_will
  centurion
  volume_king
  social_butterfly
  group_founder
  challenger_3
  chat_starter
  streak_3weeks
  level_5_badge
}

enum NotificationType {
  new_follower
  group_invite
  rank_surpassed
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String?  @unique
  name      String?
  image     String?
  password  String?
  plan        Plan      @default(free)
  role        Role      @default(USER)
  isPublic    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Auth / session management
  emailVerified        DateTime?
  emailVerifyToken     String?   @unique
  emailVerifyExpires   DateTime?
  googleSub            String?   @unique
  sessionVersion       Int       @default(0)
  resetPasswordToken   String?   @unique
  resetPasswordExpires DateTime?
  notificationPrefs    Json?

  // Stripe
  stripeCustomerId String? @unique

  profile      UserProfile?
  chats        Chat[]
  workoutLogs  WorkoutLog[]
  weightLogs   WeightLog[]
  achievements Achievement[]
  dailyCounts  DailyMessageCount[]
  streak       Streak?
  checkIns     WeeklyCheckIn[]
  xp           UserXP?
  challenges   UserChallenge[]
  followers    Follow[]        @relation("UserFollowers")
  following    Follow[]        @relation("UserFollowing")
  groupsCreated Group[]        @relation("GroupCreator")
  groupMembers  GroupMember[]  @relation("GroupMemberships")
  notifications Notification[]
  routines      Routine[]
  sentFollowRequests     FollowRequest[]  @relation("SentFollowRequests")
  receivedFollowRequests FollowRequest[]  @relation("ReceivedFollowRequests")
  sentGroupInvitations   GroupInvitation[] @relation("SentGroupInvitations")
  receivedGroupInvitations GroupInvitation[] @relation("ReceivedGroupInvitations")
}

// ─── Security infrastructure ─────────────────────────────────────────────────

model RateLimit {
  id          String   @id @default(cuid())
  key         String
  windowStart DateTime
  count       Int      @default(0)

  @@unique([key, windowStart])
  @@index([windowStart])
}

model StripeEvent {
  id         String   @id // Stripe event id — natural primary key prevents replay
  type       String
  receivedAt DateTime @default(now())

  @@index([receivedAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // e.g. "user.delete", "plan.upgrade", "admin.delete_user"
  target    String?  // target id (other user, chat, etc.)
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model UserProfile {
  id              String      @id @default(cuid())
  userId          String      @unique
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  birthDate       DateTime
  weight          Float
  height          Float
  gender          Gender
  goal            Goal
  level           Level
  daysPerWeek     Int
  sessionTime     String      // '<30' | '30-45' | '45-60' | '>60'
  workoutType     WorkoutType
  schedule        Schedule
  injuries        String?
  allergies       String?
  foodPreferences String[]
  extraInfo       String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Chat {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String    @default("Nueva conversación")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  messages Message[]
}

model Message {
  id        String      @id @default(cuid())
  chatId    String
  chat      Chat        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role      MessageRole
  content   String      @db.Text
  createdAt DateTime    @default(now())
}

model WorkoutLog {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date         DateTime @default(now())
  // DEPRECATED legacy blob — superseded by the `exercises` relation below.
  // Kept (nullable) as a rollback safety net; a follow-up migration drops the column.
  legacyExercises Json? @map("exercises")
  exercises    WorkoutExercise[]
  duration     Int
  completed    Boolean  @default(false)
  notes        String?
  routineId    String?
  routineDayId String?
  createdAt    DateTime @default(now())
}

model WorkoutExercise {
  id           String     @id @default(cuid())
  workoutLogId String
  workoutLog   WorkoutLog @relation(fields: [workoutLogId], references: [id], onDelete: Cascade)
  // userId + date are denormalized from the parent log so cross-session per-exercise
  // stats (e.g. bench-press progression, group rankings) are an indexed query.
  userId       String
  date         DateTime
  name         String
  sets         Int
  reps         Int
  weight       Float
  order        Int

  @@index([workoutLogId])
  @@index([userId, name, date])
}

model WeightLog {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weight Float
  date   DateTime @default(now())
}

model Achievement {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge      BadgeId
  unlockedAt DateTime @default(now())

  @@unique([userId, badge])
}

model DailyMessageCount {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date   DateTime @db.Date
  count  Int      @default(0)

  @@unique([userId, date])
}

model Streak {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak     Int      @default(0)
  bestStreak        Int      @default(0)
  lastCompletedWeek String?  // ISO week: "YYYY-Www"
  updatedAt         DateTime @updatedAt
}

model UserXP {
  id      String @id @default(cuid())
  userId  String @unique
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalXP Int    @default(0)
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model UserChallenge {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeId String
  weekStart   DateTime  @db.Date
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([userId, challengeId, weekStart])
}

model Group {
  id        String        @id @default(cuid())
  name      String
  createdBy String
  creator   User          @relation("GroupCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  members   GroupMember[]
  invitations GroupInvitation[]
  createdAt DateTime      @default(now())
}

model GroupMember {
  id       String   @id @default(cuid())
  groupId  String
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation("GroupMemberships", fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       NotificationType
  title      String
  body       String?
  href       String?
  fromUserId String?
  read       Boolean          @default(false)
  createdAt  DateTime         @default(now())

  @@index([userId, createdAt])
  @@index([userId, read])
}

model Routine {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  days      RoutineDay[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([userId])
}

model RoutineDay {
  id        String          @id @default(cuid())
  routineId String
  routine   Routine         @relation(fields: [routineId], references: [id], onDelete: Cascade)
  dayIndex  Int
  name      String
  exercises RoutineExercise[]

  @@index([routineId])
}

model RoutineExercise {
  id           String     @id @default(cuid())
  routineDayId String
  routineDay   RoutineDay @relation(fields: [routineDayId], references: [id], onDelete: Cascade)
  name         String
  sets         Int
  reps         String
  restSeconds  Int?
  order        Int

  @@index([routineDayId])
}

model WeeklyCheckIn {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart     DateTime @db.Date
  response      String   @db.Text
  aiSuggestions String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, weekStart])
}

model FollowRequest {
  id         String   @id @default(cuid())
  fromUserId String
  from       User     @relation("SentFollowRequests",     fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  to         User     @relation("ReceivedFollowRequests", fields: [toUserId],   references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([fromUserId, toUserId])
  @@index([fromUserId])
  @@index([toUserId])
}

model GroupInvitation {
  id        String   @id @default(cuid())
  groupId   String
  group     Group    @relation(fields: [groupId],   references: [id], onDelete: Cascade)
  inviterId String
  inviter   User     @relation("SentGroupInvitations",     fields: [inviterId], references: [id], onDelete: Cascade)
  inviteeId String
  invitee   User     @relation("ReceivedGroupInvitations", fields: [inviteeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([groupId, inviteeId])
  @@index([inviteeId])
}
